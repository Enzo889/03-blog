---
import type { CollectionEntry } from "astro:content";
import { Formatter } from "../utils/formatter";
import { Image } from "astro:assets";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<a href={`/posts/${post.id}`} class="card block" style="text-decoration:none;">
  <Image
    src={post.data.image}
    alt={post.data.title}
    width={600}
    height={340}
    loading="lazy"
    class="w-full h-48 object-cover"
  />
  <div class="p-5">
    <div class="flex flex-wrap gap-2 mb-3">
      {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
    <h3 class="text-lg font-semibold text-white mt-0 mb-2" style="margin-top:0;">
      {post.data.title}
    </h3>
    <p class="text-sm mb-3" style="color: var(--color-text-muted); margin-top:0;">
      {post.data.description}
    </p>
    <span class="text-xs" style="color: var(--color-text-dim);">
      {Formatter.FormDate(post.data.date)}
    </span>
  </div>
</a>
