---
import { Formatter } from "../utils/formatter";

const { frontmatter, url } = Astro.props;
---

<a href={url} class="card block" style="text-decoration:none;">
  <div class="lg:flex">
    <img
      class="object-cover w-full h-48 lg:w-64 lg:h-auto"
      src={frontmatter.image}
      alt={frontmatter.title}
    />
    <div class="flex flex-col justify-between p-5">
      <div>
        <h3 class="text-lg font-semibold text-white mt-0 mb-2" style="margin-top:0;">
          {frontmatter.title}
        </h3>
        <p class="text-sm" style="color: var(--color-text-muted); margin-top:0;">
          {frontmatter.description}
        </p>
      </div>
      <span class="text-xs mt-3" style="color: var(--color-text-dim);">
        {Formatter.FormDate(frontmatter.date)}
      </span>
    </div>
  </div>
</a>
