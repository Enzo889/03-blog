---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  author: CollectionEntry<"author">;
}

const { author } = Astro.props;
const { avatar, bio, github, linkedIn, name, subtitle, twitter } = author.data;
---

<div class="card p-6 text-center">
  <Image
    class="w-24 h-24 rounded-full mx-auto object-cover"
    src={avatar}
    alt={`${name}'s profile picture`}
    width={200}
    height={200}
    quality={"mid"}
  />
  <h2 class="text-xl font-semibold mt-4 mb-1 text-white" style="margin-bottom:0.25rem;">{name}</h2>
  <p class="text-sm" style="color: var(--color-text-dim); margin-top:0.25rem;">{subtitle}</p>

  <div class="flex justify-center gap-3 mt-4 flex-wrap">
    <a
      href={`https://x.com/${twitter}`}
      class="btn-outline btn text-xs"
      style="text-decoration:none; padding: 0.375rem 0.75rem;"
      target="_blank"
    >Twitter</a>
    <a
      href={linkedIn}
      class="btn-outline btn text-xs"
      style="text-decoration:none; padding: 0.375rem 0.75rem;"
      target="_blank"
    >LinkedIn</a>
    <a
      href={github}
      class="btn-outline btn text-xs"
      style="text-decoration:none; padding: 0.375rem 0.75rem;"
      target="_blank"
    >GitHub</a>
  </div>

  <p class="text-sm mt-4" style="color: var(--color-text-muted);">{bio}</p>

  <a href={`/blog/${author.id}`} class="btn text-sm mt-3 inline-block" style="text-decoration:none;">
    View Posts →
  </a>
</div>
