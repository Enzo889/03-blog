---
import { getCollection } from "astro:content";
import TypedBlogPost from "../components/TypedBlogPost.astro";
import MainLayout from "../layouts/MainLayout.astro";

const blogPosts = await getCollection(
  "blog",
  (post) => post.data.isDraft === false,
);
---

<MainLayout title="Home">
  <section class="mb-12">
    <h1 class="text-5xl font-extrabold tracking-tight mb-4">
      Welcome to <span style="color: var(--color-accent);">DevBlog</span>
    </h1>
    <p class="text-lg" style="color: var(--color-text-muted); max-width: 36rem;">
      Explore articles about web development, programming, and modern technologies written by our community of authors.
    </p>
  </section>

  <section>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-semibold text-white" style="margin:0;">Latest Posts</h2>
      <a href="/blog/1" class="btn text-sm" style="text-decoration:none;">View All →</a>
    </div>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {blogPosts.map((post) => <TypedBlogPost post={post} />)}
    </div>
  </section>
</MainLayout>
