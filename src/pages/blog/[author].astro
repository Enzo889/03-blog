---
import MainLayout from "../../layouts/MainLayout.astro";
import TypedBlogPost from "../../components/TypedBlogPost.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

export const getStaticPaths = async () => {
  const posts = await getCollection("blog");
  const authors = await getCollection("author");

  return authors.map((author) => {
    const blogPosts = posts.filter((post) => post.data.author.id === author.id);
    return {
      params: { author: author.id },
      props: { blogPosts, author },
    };
  });
};

const { blogPosts, author } = Astro.props;
---

<MainLayout title={`Posts by ${author.data.name}`}>
  <section class="mb-10">
    <div class="flex items-center gap-5 mb-6">
      <Image
        class="w-16 h-16 rounded-full object-cover"
        src={author.data.avatar}
        quality={"mid"}
        alt={author.data.name}
        width={100}
        height={100}
      />
      <div>
        <h1 class="text-3xl font-bold mb-1" style="margin:0;">{author.data.name}</h1>
        <p class="text-sm" style="color: var(--color-text-muted); margin:0;">
          All posts by this author
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {blogPosts.map((post) => <TypedBlogPost post={post} />)}
    </div>
  </section>
</MainLayout>
