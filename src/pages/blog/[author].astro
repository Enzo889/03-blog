---
import MainLayout from "../../layouts/MainLayout.astro";
import TypedBlogPost from "../../components/TypedBlogPost.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

export const getStaticPaths = async () => {
  const posts = await getCollection("blog");
  const authors = await getCollection("author");

  return authors.map((author) => {
    const blogPosts = posts.filter((post) => post.data.author.id === author.id);
    return {
      params: { author: author.id },
      props: { blogPosts, author },
    };
  });
};

const { blogPosts, author } = Astro.props;
---

<MainLayout title={`Posts by ${author.data.name}`}>
  <section class="bg-gray-900">
    <div class="container px-6 py-10 mx-auto">
      <h1 class="text-3xl font-semibold capitalize lg:text-4xl text-white">
        All Posts by {author.data.name}
      </h1>
      <a href="/">Back to Homepage</a>

      <div class="text-md text-gray-400 mb-0 flex flex-row mt-2">
        <Image
          class="rounded-full"
          src={author.data.avatar}
          quality={"mid"}
          alt={author.data.name}
          width={50}
          height={50}
        />

        <div class="flex flex-col ml-5">
          <a>{author.data.name}</a>
          <span>Listado de todos mis posts</span>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-8 mt-8 md:mt-16 md:grid-cols-2">
        {blogPosts.map((post) => <TypedBlogPost post={post} />)}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  a {
    color: oklch(62.3% 0.214 259.815)

     &:hover {
      @media (hover: hover) {
        text-decoration-line: underline;
      }
    }
  }
</style>
