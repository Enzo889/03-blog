---
import type { GetStaticPaths } from "astro";
import TypedBlogPost from "../../components/TypedBlogPost.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

// Type GetStaticPaths de Astro
export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog");
  return paginate(posts, { pageSize: 2 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<MainLayout title="Blogs List">
  <a href={`/`}>Back to Homepage</a>

  <div class="py-10 mx-auto">
    <h1 class="text-3xl font-semibold capitalize lg:text-4xl text-white">
      Enzo's Blog paginado
    </h1>
  </div>

  <section class="bg-gray-900" aria-label="Entradas de blog">
    <div class="grid grid-cols-1 gap-8 mt-8 md:mt-16 md:grid-cols-2">
      {page.data.map((post) => <TypedBlogPost post={post} />)}
    </div>
  </section>

  <section aria-label="Controles" class="flex justify-between mt-10">
    <!--   page .. ?? prev   -->
    <a
      href={page.url.prev}
      class:list={{
        disabled: !page.url.prev,
      }}>Anteriores</a
    >

    <!--   page .. ?? next   -->
    <a
      href={page.url.next}
      class:list={{
        disabled: !page.url.next,
      }}>Siguientes</a
    >
  </section>
</MainLayout>

<style>
  a {
    background-color: #3b82f6;
    color: white;
    padding: 0.5rem;
    border-radius: 0.25rem;
    cursor: pointer;
  }

  a:hover {
    background-color: #2563eb;
  }

  .disabled {
    background-color: #4b5563;
  }

  .disabled:hover {
    background-color: #4b5563;
  }
</style>
