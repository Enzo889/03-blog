---
import type { GetStaticPaths } from "astro";
import TypedBlogPost from "../../components/TypedBlogPost.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog");
  return paginate(posts, { pageSize: 2 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<MainLayout title="Blog">
  <section class="mb-8">
    <h1 class="text-4xl font-bold tracking-tight">Blog</h1>
    <p style="color: var(--color-text-muted);">
      Page {page.currentPage} of {page.lastPage}
    </p>
  </section>

  <section>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {page.data.map((post) => <TypedBlogPost post={post} />)}
    </div>
  </section>

  <section class="flex justify-between items-center mt-10">
    {page.url.prev ? (
      <a href={page.url.prev} class="btn text-sm" style="text-decoration:none;">← Previous</a>
    ) : (
      <span class="btn btn-disabled text-sm">← Previous</span>
    )}

    {page.url.next ? (
      <a href={page.url.next} class="btn text-sm" style="text-decoration:none;">Next →</a>
    ) : (
      <span class="btn btn-disabled text-sm">Next →</span>
    )}
  </section>
</MainLayout>
