---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Page Not Found">
  <section class="flex flex-col items-center justify-center text-center py-24">
    <p
      class="text-9xl font-extrabold tracking-tight"
      style="color: var(--color-accent); margin: 0; line-height: 1;"
    >
      404
    </p>
    <h1 class="text-3xl font-bold mt-4 mb-2" style="margin-bottom: 0.5rem;">
      Page Not Found
    </h1>
    <p class="text-lg max-w-md" style="color: var(--color-text-muted);">
      Oops! The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/" class="btn mt-8" style="text-decoration: none;">
      ← Back to Home
    </a>
  </section>
</MainLayout>
